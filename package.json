{
  "name": "linkworks-crm",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "Linkworks CRM - Logistics docket management system",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "imapflow": "^1.3.1",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "pdf-parse": "^2.4.5",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
